  (-> inlet3 (expr0 2))
  (-> expr0 outlet4))

(graph string?
  (expr0 (expr (string? $x)))
  (inlet1 (inlet "value" "value to test"))
  (outlet2 (outlet "boolean" "true if a string"))
  (-> inlet1 expr0)
  (-> expr0 outlet2))

