(graph abs
  (expr0 (expr (abs $x)))
  (inlet1 (inlet "number" "value"))
  (outlet2 (outlet "number" "absolute value"))
  (-> inlet1 expr0)
  (-> expr0 outlet2))

(graph add
  (expr0 (expr (+ $l $r)))
  (inlet1 (inlet "number" "left operand"))
  (inlet2 (inlet "number" "right operand"))
  (outlet3 (outlet "number" "sum"))
  (-> inlet1 expr0)
  (-> inlet2 (expr0 1))
  (-> expr0 outlet3))

(graph and
  (expr0 (expr (if $l $r #f)))
  (inlet1 (inlet "boolean" "left operand"))
  (inlet2 (inlet "boolean" "right operand"))
  (outlet3 (outlet "boolean" "true if both are truthy"))
  (-> inlet1 expr0)
  (-> inlet2 (expr0 1))
  (-> expr0 outlet3))

(graph append
  (expr0 (expr (append $l $r)))
  (inlet1 (inlet "list" "first list"))
  (inlet2 (inlet "list" "second list"))
  (outlet3 (outlet "list" "concatenated list"))
  (-> inlet1 expr0)
  (-> inlet2 (expr0 1))
  (-> expr0 outlet3))

(graph cons
  (expr0 (expr (cons $head $tail)))
  (inlet1 (inlet "value" "new first element"))
  (inlet2 (inlet "list" "rest of the list"))
  (outlet3 (outlet "list" "new list"))
  (-> inlet1 expr0)
  (-> inlet2 (expr0 1))
  (-> expr0 outlet3))

